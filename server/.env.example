PORT=8000
MONGO_URI=your_mongodb_uri
JWT_SECRET=your_jwt_secret

# Nodemailer Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
ENABLE_EMAILS=true # Set to false to disable email sending completely in dev

# Alternative: Resend API Configuration (Recommended for Render deployment)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev # Or your verified sender email

# Cloudinary Configuration
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# AI Configuration (Groq)
GROQ_API_KEY=your_groq_api_key

# Admin Configuration
ADMIN_EMAIL=admin@arogyam.com
ADMIN_PASSWORD=admin_password
